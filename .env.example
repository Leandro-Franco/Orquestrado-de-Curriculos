# Copie para .env e ajuste os valores.

# Banco de dados
POSTGRES_DB=curriculos
POSTGRES_USER=curriculos
POSTGRES_PASSWORD=curriculos

# Serviço de IA
# fake  -> provedor determinístico local, sem custo, para desenvolvimento
# anthropic -> provedor real (exige ANTHROPIC_API_KEY)
AI_PROVIDER=fake
ANTHROPIC_API_KEY=

# Modelos por nível (seção 10 do Contexto Mestre)
AI_MODEL_ECONOMICO=claude-haiku-4-5
AI_MODEL_INTERMEDIARIO=claude-sonnet-5
AI_MODEL_AVANCADO=claude-opus-4-8
